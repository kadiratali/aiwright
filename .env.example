# Claude API key (required for AI test generation and failure analysis)
ANTHROPIC_API_KEY=sk-ant-...

# URL of the application under test
BASE_URL=https://getmobil.com

# Base URL for the API suite (npm run test:api). Defaults to the local mock in mock/server.ts.
API_BASE_URL=http://localhost:4010
# MOCK_API_PORT=4010

# true = run the browser headless
HEADLESS=true
