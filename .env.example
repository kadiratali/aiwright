# Claude API key (required for AI test generation and failure analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Target app + API + spec live in aiwright.config.ts (the one place to retarget the suite).
# These env vars OVERRIDE that config at runtime (handy for CI / per-environment runs):

# UI under test (overrides aiwright.config.ts targetUrl). TARGET_URL takes precedence over BASE_URL.
BASE_URL=https://getmobil.com
# TARGET_URL=https://getmobil.com

# API under test (overrides apiBaseUrl). Defaults to the local mock in mock/server.ts.
API_BASE_URL=http://localhost:4010
# MOCK_API_PORT=4010

# OpenAPI spec `probe` grounds API generation in (overrides openApiSpec).
# OPENAPI_SPEC=docs/api/openapi.json

# true = run the browser headless
HEADLESS=true
